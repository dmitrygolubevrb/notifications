{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Сервис уведомлений",
		"description": "API микросервиса уведомлений (Laravel).\n\n## Как начать\n\n1. Запусти проект: `docker compose up -d`\n   — контейнер `app` сам накатит миграции и сгенерирует токен (см. `docker/setup/entrypoint.sh`)\n2. Дождись, пока сервис станет healthy: `docker compose ps`\n3. Открой `.env` и скопируй значение `POSTMAN_API_TOKEN` в переменную коллекции **token**\n4. Запусти папку **«Полный сценарий»** по порядку, начиная с шага 0\n\nВоркер очереди стартует автоматически. Если уведомления не обрабатываются: `docker compose logs -f worker`\n\n## Переменные коллекции\n\n| Переменная | Значение по умолчанию | Зачем нужна |\n|------------|----------------------|-------------|\n| `baseUrl` | `http://localhost:8000/api/v1` | Адрес API |\n| `token` | *(пусто)* | Токен авторизации из `.env` |\n| `subscriberId` | `user-demo` | Внешний ID подписчика |\n| `idempotencyKey` | *(авто)* | Ключ идемпотентности для POST-запросов |\n| `fixedIdempotencyKey` | `postman-idempotency-demo` | Фиксированный ключ для теста идемпотентности |\n",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (!pm.collectionVariables.get('idempotencyKey')) {",
					"    pm.collectionVariables.set('idempotencyKey', pm.variables.replaceIn('{{$guid}}'));",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000/api/v1"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "subscriberId",
			"value": "user-demo"
		},
		{
			"key": "idempotencyKey",
			"value": ""
		},
		{
			"key": "fixedIdempotencyKey",
			"value": "postman-idempotency-demo"
		}
	],
	"item": [
		{
			"name": "Полный сценарий",
			"description": "Основной путь проверки: создать подписчика → отправить уведомления → дождаться воркера → проверить статусы.",
			"item": [
				{
					"name": "0. Создать подписчика",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    pm.test('Статус 201 — подписчик создан', () => {",
									"        pm.response.to.have.status(201);",
									"    });",
									"",
									"    const body = pm.response.json();",
									"",
									"    pm.test('В ответе есть объект subscriber', () => {",
									"        pm.expect(body).to.have.property('subscriber');",
									"    });",
									"",
									"    pm.collectionVariables.set('subscriberId', body.subscriber.external_id);",
									"} else {",
									"    pm.test('Подписчик уже существует — статус 422', () => {",
									"        pm.response.to.have.status(422);",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"external_id\": \"{{subscriberId}}\",\n  \"phone\": \"+79001234567\",\n  \"email\": \"demo@example.com\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/subscribers",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"subscribers"
							]
						},
						"description": "Регистрирует нового подписчика в системе.\n\nЕсли подписчик с таким `external_id` уже есть — вернётся **422**. Это нормально: дальнейшие шаги будут работать с уже существующим подписчиком."
					},
					"response": []
				},
				{
					"name": "1. Отправить одно SMS (срочное)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.collectionVariables.set('idempotencyKey', pm.variables.replaceIn('{{$guid}}'));"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Статус 202 — запрос принят', () => {",
									"    pm.response.to.have.status(202);",
									"});",
									"",
									"const body = pm.response.json();",
									"",
									"pm.test('В ответе есть объект notification', () => {",
									"    pm.expect(body).to.have.property('notification');",
									"});",
									"",
									"pm.test('Статус уведомления — queued (в очереди)', () => {",
									"    pm.expect(body.notification.status).to.eql('queued');",
									"});",
									"",
									"pm.test('Канал — sms', () => {",
									"    pm.expect(body.notification.channel).to.eql('sms');",
									"});",
									"",
									"pm.collectionVariables.set('lastNotificationId', String(body.notification.id));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Idempotency-Key",
								"value": "{{idempotencyKey}}",
								"description": "Уникальный ключ — защита от повторной отправки"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"subscriber_external_id\": \"{{subscriberId}}\",\n  \"channel\": \"sms\",\n  \"priority\": \"transactional\",\n  \"message\": \"Код доступа: 4821\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/notifications",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"notifications"
							]
						},
						"description": "Отправляет одно срочное SMS с наивысшим приоритетом.\n\nУходит в очередь `notifications.high`.\n\n**После ответа подожди 5–10 секунд** и выполни шаг 3 — статус должен смениться на `sent`, затем `delivered`."
					},
					"response": []
				},
				{
					"name": "2. Массовая email-рассылка (маркетинг)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.collectionVariables.set('idempotencyKey', pm.variables.replaceIn('{{$guid}}'));"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Статус 202 — запрос принят', () => {",
									"    pm.response.to.have.status(202);",
									"});",
									"",
									"const body = pm.response.json();",
									"",
									"pm.test('В ответе есть поля пакета рассылки', () => {",
									"    pm.expect(body).to.have.all.keys('batch_id', 'channel', 'priority', 'message', 'total_count', 'notifications');",
									"});",
									"",
									"pm.test('Количество совпадает с массивом уведомлений', () => {",
									"    pm.expect(body.notifications).to.be.an('array');",
									"    pm.expect(body.total_count).to.eql(body.notifications.length);",
									"});",
									"",
									"pm.test('Все уведомления в статусе queued', () => {",
									"    body.notifications.forEach(n => pm.expect(n.status).to.eql('queued'));",
									"});",
									"",
									"pm.collectionVariables.set('lastBatchId', String(body.batch_id));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Idempotency-Key",
								"value": "{{idempotencyKey}}",
								"description": "Уникальный ключ — защита от повторной отправки"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"subscriber_external_ids\": [\"{{subscriberId}}\"],\n  \"channel\": \"email\",\n  \"priority\": \"marketing\",\n  \"message\": \"Специальное предложение только для вас!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/notifications/bulk",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"notifications",
								"bulk"
							]
						},
						"description": "Массовая рассылка с низким приоритетом.\n\nУходит в очередь `notifications.low`."
					},
					"response": []
				},
				{
					"name": "3. Получить все уведомления подписчика",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Статус 200 — успех', () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const body = pm.response.json();",
									"",
									"pm.test('Ответ с пагинацией (data, links, meta)', () => {",
									"    pm.expect(body).to.have.all.keys('data', 'links', 'meta');",
									"    pm.expect(body.data).to.be.an('array');",
									"});",
									"",
									"pm.test('У каждого уведомления есть нужные поля', () => {",
									"    if (body.data.length > 0) {",
									"        const item = body.data[0];",
									"        pm.expect(item).to.have.all.keys('id', 'status', 'channel', 'message', 'priority', 'created_at');",
									"    }",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/subscribers/{{subscriberId}}/notifications",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"subscribers",
								"{{subscriberId}}",
								"notifications"
							]
						},
						"description": "Возвращает историю уведомлений подписчика.\n\nПосле обработки воркером статус сменится на `delivered`."
					},
					"response": []
				},
				{
					"name": "4. Получить только доставленные",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Статус 200 — успех', () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const body = pm.response.json();",
									"",
									"pm.test('Все уведомления в статусе delivered', () => {",
									"    body.data.forEach(n => pm.expect(n.status).to.eql('delivered'));",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
